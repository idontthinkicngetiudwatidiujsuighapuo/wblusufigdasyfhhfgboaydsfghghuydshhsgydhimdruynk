local function findBestTarget_q()
local best, bestScore = nil, -math.huge
local camPos = Camera.CFrame.Position
local camLook = Camera.CFrame.LookVector
for _, player in ipairs(Players:GetPlayers()) do
if player ~= LocalPlayer and player.Character then
local hum = player.Character:FindFirstChildOfClass("Humanoid")
local root = player.Character:FindFirstChild("HumanoidRootPart")
if hum and root and hum.Health > 0 then
local dist = (camPos - root.Position).Magnitude
local toTarget = (root.Position - camPos).Unit
local dot = toTarget:Dot(camLook)
local angleDeg = math.deg(math.acos(clamp_q(dot, -1, 1)))
if angleDeg <= CFG.LOCK_FOV then
local score = (1 / math.max(dist, 1)) * 1000 - angleDeg * 5
if score > bestScore then
bestScore = score
best = player
end
end
end
end
end
return best, bestScore
end

local function resolveTarget_q(target, dt)
if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
return nil
end
local thrp = target.Character.HumanoidRootPart
local pos, vel = thrp.Position, thrp.AssemblyLinearVelocity
local name = target.Name
if not resolverHistory_q[name] then
resolverHistory_q[name] = {lastVel = vel, adaptiveOffset = Vector3.zero, history = {}}
end
local history = resolverHistory_q[name]
table.insert(history.history, 1, {pos = pos, vel = vel})
if #history.history > CFG.RESOLVER_HISTORY_SIZE then
table.remove(history.history)
end
return pos + vel * CFG.PREDICTION + smoothAccel_q * CFG.ACCEL_WEIGHT
end

