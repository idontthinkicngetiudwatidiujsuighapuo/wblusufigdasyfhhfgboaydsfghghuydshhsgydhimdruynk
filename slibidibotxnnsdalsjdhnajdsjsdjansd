local function getClosestInFOV_q()
local target = nil
local shortest = math.huge
local fovLimit = Options.FovRadius.Value
local maxDist = Options.MaxStudsAimbot.Value
local targetSetting = Options.AimTarget.Value
for _, player in ipairs(Players:GetPlayers()) do
if player == LocalPlayer then
continue
end
if checkSameTeam_q(player) then
continue
end
local char = player.Character
if not char then
continue
end
local hum = char:FindFirstChildOfClass("Humanoid")
if not hum or hum.Health <= 0 then
continue
end
local checkPart = char:FindFirstChild(targetSetting) or char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
if targetSetting == "Closest to mouse" then
checkPart = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
end
if not checkPart then
continue
end
local dist = (checkPart.Position - Camera.CFrame.Position).Magnitude
if dist > maxDist then
continue
end
if not checkVisible_q(checkPart) then
continue
end
local sp, on = Camera:WorldToViewportPoint(checkPart.Position)
if not on then
continue
end
local d = (Vector2.new(sp.X, sp.Y) - UserInputService:GetMouseLocation()).Magnitude
if d < shortest and d <= fovLimit then
shortest = d
target = player
end
end
return target
end

