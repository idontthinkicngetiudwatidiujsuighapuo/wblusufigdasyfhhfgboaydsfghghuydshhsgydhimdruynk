local function checkVoidEvasion_q()
if not CFG.VOID_EVADE_ENABLED or voidEvadeCooldown_q > 0 then
return
end
local minDist = math.huge
local threatVector = Vector3.new()
for _, p in pairs(Players:GetPlayers()) do
if p ~= LocalPlayer and p.Character then
local hrp2 = p.Character:FindFirstChild("HumanoidRootPart")
local hum2 = p.Character:FindFirstChildOfClass("Humanoid")
if hrp2 and hum2 and hum2.Health > 0 then
local dist = (hrp2.Position - intendedVoidPos_q).Magnitude
local predPos = hrp2.Position + hrp2.AssemblyLinearVelocity * 0.5
local score = dist * 0.7 + (predPos - intendedVoidPos_q).Magnitude * 0.3
if score < minDist then
minDist = score
threatVector = (predPos - intendedVoidPos_q).Unit
end
end
end
end
if minDist < CFG.VOID_EVADE_RADIUS then
local esc = threatVector * -1
local threatLevel = math.max(0, 1 - (minDist / CFG.VOID_EVADE_RADIUS))
voidX_q = voidX_q + esc.X * CFG.VOID_EVADE_SPEED * (1 + threatLevel)
voidZ_q = voidZ_q + esc.Z * CFG.VOID_EVADE_SPEED * (1 + threatLevel)
if math.random() < CFG.VOID_EVADE_VERT_BIAS then
local vdir = CFG.VOID_EVADE_FORCE_UP and 1 or (math.random() > 0.5 and 1 or -1)
voidYOffset_q = voidYOffset_q + vdir * CFG.VOID_EVADE_VERT_SPEED
end
voidEvadeCooldown_q = CFG.VOID_EVADE_COOLDOWN
end
end

