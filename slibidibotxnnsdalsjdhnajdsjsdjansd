local unlockConfig = { unlockAllWeapons = false, unlockAllCosmetics = false }
local equipped_u = {}
local spoofCache_u = {}
local unlockedItems_u = {}
local dataCtrl_u = nil
local cosmeticLib_u = nil
local itemLib_u = nil

local fileName = "QClientCosmetics.json"

local function saveSettings()
if not equipped_u or next(equipped_u) == nil then
return
end
task.spawn(function()
local success, content = pcall(HttpService.JSONEncode, HttpService, equipped_u)
if success then
writefile(fileName, content)
end
end)
end

local function loadSettings()
task.defer(function()
if not isfile(fileName) then
return
end
local s, content = pcall(readfile, fileName)
if s and #content > 2 then
local ds, decoded = pcall(HttpService.JSONDecode, HttpService, content)
if ds and type(decoded) == "table" then
equipped_u = decoded
end
end
end)
end

local function anyUnlockEnabled_u()
if not unlockConfig then
return false
end
return unlockConfig.unlockAllWeapons or unlockConfig.unlockAllCosmetics
end

loadSettings()

task.defer(function()
local TIMEOUT = 30
local lp = game:GetService("Players").LocalPlayer
local rs = game:GetService("ReplicatedStorage")

if not game:IsLoaded() then
game.Loaded:Wait()
end

local ok1, rs2 = pcall(function()
return cloneref(rs)
end)
if not ok1 then
rs2 = rs
end

local mods = rs2:WaitForChild("Modules", TIMEOUT)
if not mods then
return
end

local function getLib(name)
local obj = mods:WaitForChild(name, TIMEOUT)
if obj then
local success, lib = pcall(require, obj)
if success then
return lib
else
if Library then
Library:Notify("Failed to load " .. name .. " module", 3)
end
end
end
return nil
end

cosmeticLib_u = getLib("CosmeticLibrary")
itemLib_u = getLib("ItemLibrary")

local ps = lp:WaitForChild("PlayerScripts", TIMEOUT)
if not ps then
return
end
local ctrls = ps:WaitForChild("Controllers", TIMEOUT)
if not ctrls then
return
end
local dCtrlObj = ctrls:WaitForChild("PlayerDataController", TIMEOUT)
if dCtrlObj then
dataCtrl_u = require(dCtrlObj)
end

if not (cosmeticLib_u and itemLib_u and dataCtrl_u) then
return
end

local oldNC
oldNC = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
local method = getnamecallmethod()
if method == "FireServer" and self.Name == "EquipCosmetic" then
if not anyUnlockEnabled_u() then
return oldNC(self, ...)
end
local args = {...}
local wN, cT, cN, opt2 = args[1], args[2], args[3], args[4]
equipped_u[wN] = equipped_u[wN] or {}

if not cN or cN == "" or cN == "None" then
equipped_u[wN][cT] = nil
else
local base = cosmeticLib_u.Cosmetics[cN]
if base then
local cl = {Name = cN, Seed = math.random(1, 1e6), Inverted = opt2 and opt2.IsInverted or false}
for k, v in pairs(base) do
cl[k] = v
end
equipped_u[wN][cT] = cl
end
end

saveSettings()
spoofCache_u[wN] = nil
if dataCtrl_u.CurrentData then
pcall(function()
dataCtrl_u.CurrentData:Replicate("WeaponInventory")
end)
end
return
end
return oldNC(self, ...)
end))

local origGWD = dataCtrl_u.GetWeaponData
dataCtrl_u.GetWeaponData = function(self, wn)
if not anyUnlockEnabled_u() then
return origGWD(self, wn)
end
if spoofCache_u[wn] then
return spoofCache_u[wn]
end

local rd = origGWD(self, wn)
local sp = {Unlocked = unlockConfig.unlockAllWeapons, Level = 100, XP = 99999, Name = wn}
if rd then
for k, v in pairs(rd) do
if k ~= "Unlocked" then
sp[k] = v
end
end
end
if unlockConfig.unlockAllCosmetics and equipped_u[wn] then
for k, v in pairs(equipped_u[wn]) do
sp[k] = v
end
end
spoofCache_u[wn] = sp
return sp
end

local origGU = dataCtrl_u.GetUnlockedWeapons
dataCtrl_u.GetUnlockedWeapons = function(self, ...)
if unlockConfig.unlockAllWeapons then
local w = {}
for n in pairs(itemLib_u.Items) do
w[n] = true
end
return w
end
return origGU(self, ...)
end

local origGet = dataCtrl_u.Get
dataCtrl_u.Get = function(self, key)
if unlockConfig.unlockAllCosmetics then
if key == "CosmeticInventory" then
return setmetatable({}, {__index = function()
return true
end})
end
if key == "WeaponInventory" then
return equipped_u
end
end
return origGet(self, key)
end

