local OrigOutAmbient = Lighting.OutdoorAmbient
local originalProps = {}
local potatoConn = nil
local lastPotatoState = false

local function applyPotato(v)
if not v or not v.Parent then
return
end
if v:IsDescendantOf(Players) or v:IsDescendantOf(workspace.CurrentCamera) then
return
end
if v:IsA("BasePart") then
if not originalProps[v] then
originalProps[v] = {Material = v.Material, Reflectance = v.Reflectance, CastShadow = v.CastShadow}
end
v.Material = Enum.Material.SmoothPlastic
v.Reflectance = 0
v.CastShadow = false
elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("Clothing") or v:IsA("SurfaceAppearance") then
if not originalProps[v] then
originalProps[v] = {Transparency = v.Transparency}
end
v.Transparency = 1
elseif v:IsA("MeshPart") then
if not originalProps[v] then
originalProps[v] = {TextureID = v.TextureID}
end
v.TextureID = ""
elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
if not originalProps[v] then
originalProps[v] = {Enabled = v.Enabled}
end
v.Enabled = false
end
end

local function undoPotato()
for obj, props in pairs(originalProps) do
pcall(function()
if obj and obj.Parent then
for prop, value in pairs(props) do
obj[prop] = value
end
end
end)
end
originalProps = {}
end

