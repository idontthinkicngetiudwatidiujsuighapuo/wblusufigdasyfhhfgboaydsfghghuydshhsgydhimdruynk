TracerCache = {}

function RemoveTracer(player)
    if TracerCache[player] then
        TracerCache[player]:Remove()
        TracerCache[player] = nil
    end
end

function GetTracer(player)
    if not TracerCache[player] then
        local line = Drawing.new("Line")
        line.Visible = false
        TracerCache[player] = line
    end
    return TracerCache[player]
end

RunService.RenderStepped:Connect(function()
    if not Toggles.TracerEn or not Toggles.TracerEn.Value then
        for _, line in pairs(TracerCache) do
            if line then
                line.Visible = false
            end
        end
        return
    end
    
    local origin
    local originType = Options.TracerOrigin and Options.TracerOrigin.Value or 'Bottom'
    
    if originType == 'Center' then
        origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    elseif originType == 'Mouse' then
        origin = UserInputService:GetMouseLocation()
    else
        origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then
            continue
        end
        
        local line = GetTracer(player)
        local char = player.Character
        
        if not char or not char.Parent then
            if line then line.Visible = false end
            continue
        end
        
        local targetPart = char:FindFirstChild(Options.TracerPart and Options.TracerPart.Value or 'Torso')
        
        if targetPart then
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            local dist = (Camera.CFrame.Position - targetPart.Position).Magnitude
            local maxDist = Options.TracerDist and Options.TracerDist.Value or 500
            
            if onScreen and dist <= maxDist then
                line.Visible = true
                line.From = origin
                line.To = Vector2.new(screenPos.X, screenPos.Y)
                line.Color = Options.TracerColor and Options.TracerColor.Value or Color3.new(1, 1, 1)
                line.Thickness = Options.TracerThick and Options.TracerThick.Value or 1
                line.Transparency = Options.TracerOp and Options.TracerOp.Value or 1
            else
                line.Visible = false
            end
        else
            if line then line.Visible = false end
        end
    end
end)

