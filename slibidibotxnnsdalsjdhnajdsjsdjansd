elseif m == "Figure 8" then
local r = minR + (maxR - minR) * 0.5
orbitOffset = Vector3.new(math.sin(orbitAngle_q) * r, CFG.HEIGHT_OFFSET, math.sin(orbitAngle_q * 2) * r)
elseif m == "Pulse" then
local pr = minR + (maxR - minR) * (0.5 + 0.5 * math.sin(elapsed_q * 5))
orbitOffset = Vector3.new(math.cos(orbitAngle_q) * pr, CFG.HEIGHT_OFFSET, math.sin(orbitAngle_q) * pr)
elseif m == "Lissajous" then
local rX = minR + (maxR - minR) * 0.7
local rZ = minR + (maxR - minR) * 0.3
orbitOffset = Vector3.new(math.sin(orbitAngle_q * 3) * rX, CFG.HEIGHT_OFFSET, math.sin(orbitAngle_q * 2) * rZ)
elseif m == "Tornado" then
local r = minR + (maxR - minR) * (0.3 + 0.7 * math.abs(math.sin(elapsed_q * 2)))
local h = CFG.HEIGHT_OFFSET + math.sin(elapsed_q * 10) * 100000
orbitOffset = Vector3.new(math.cos(orbitAngle_q * 3) * r, h, math.sin(orbitAngle_q * 3) * r)
elseif m == "Hyper Elliptical" then
local rX = minR + (maxR - minR) * CFG.ELLIPSE_RATIO
local rZ = minR + (maxR - minR) * (1 - CFG.ELLIPSE_RATIO)
orbitOffset = Vector3.new(math.cos(orbitAngle_q) * rX, CFG.HEIGHT_OFFSET, math.sin(orbitAngle_q) * rZ)
elseif m == "Quantum Orbit" then
local r = minR + (maxR - minR) * (0.5 + 0.5 * math.sin(elapsed_q * 13))
local qp = math.sin(elapsed_q * 7) * math.pi
orbitOffset = Vector3.new(math.cos(orbitAngle_q + qp) * r, CFG.HEIGHT_OFFSET + math.sin(qp * 2) * 50000, math.sin(orbitAngle_q + qp) * r)
else
local r = minR + (maxR - minR) * 0.5
orbitOffset = Vector3.new(math.cos(orbitAngle_q) * r, CFG.HEIGHT_OFFSET, math.sin(orbitAngle_q) * r)
end
if CFG.ORBIT_JITTER > 0 then
orbitOffset = orbitOffset + Vector3.new(
math.random(-CFG.ORBIT_JITTER, CFG.ORBIT_JITTER),
math.random(-CFG.ORBIT_JITTER, CFG.ORBIT_JITTER),
math.random(-CFG.ORBIT_JITTER, CFG.ORBIT_JITTER)
)
end
local targetPos = resolvedPos + orbitOffset
local targetCF = CFrame.lookAt(targetPos, resolvedPos)
local lerp = clamp_q(CFG.CAM_LERP_BASE, CFG.CAM_LERP_BASE, 0.45)
Camera.CFrame = Camera.CFrame:Lerp(targetCF, lerp * CFG.ORBIT_STABILITY)
end

local function toggleOrbit_q(enabled)
OrbitEnabled_q = enabled
if enabled then
if OrbitConnection_q then
OrbitConnection_q:Disconnect()
end
OrbitConnection_q = RunService.RenderStepped:Connect(function(dt)
if not OrbitEnabled_q then
return
end
if reacquireTimer_q > 0 then
reacquireTimer_q = reacquireTimer_q - dt
end
if not currentTarget_q or not currentTarget_q.Character or not currentTarget_q.Character:FindFirstChild("HumanoidRootPart") then
local newT, newS = findBestTarget_q()
if newT then
currentTarget_q = newT
currentTargetScore_q = newS
reacquireTimer_q = 0.5
end
end
if not currentTarget_q then
return
end
local resolvedPos = resolveTarget_q(currentTarget_q, dt)
if not resolvedPos then
return
end
local currentVel = (resolvedPos - (smoothedPredicted_q or resolvedPos)) / math.max(dt, 0.001)
smoothAccel_q = smoothAccel_q:Lerp((currentVel - lastVelocity_q) / math.max(dt, 0.001), CFG.ACCEL_SMOOTH)
lastVelocity_q = currentVel
smoothedPredicted_q = resolvedPos
orbitCamera_q(dt, resolvedPos)
end)
Library:Notify('Orbit Camera: ON', 2)
else
if OrbitConnection_q then
OrbitConnection_q:Disconnect()
OrbitConnection_q = nil
end
local char = LocalPlayer.Character
if char then
local hum = char:FindFirstChildOfClass("Humanoid")
if hum then
Camera.CameraSubject = hum
Camera.CameraType = Enum.CameraType.Follow
end
end
Library:Notify('Orbit Camera: OFF', 2)
end
end

voidHeartbeatConn = RunService.Heartbeat:Connect(function(dt)
elapsed_q = elapsed_q + dt
if VoidEnabled_q then
lockToVoid_q(dt)
end
end)

table.insert(cleanupConnections, voidHeartbeatConn)

