local function clamp_q(x, mn, mx)
if x < mn then
return mn
elseif x > mx then
return mx
end
return x
end

local function computeVoidDriftDir_q(t)
local nx, nz, amp, freq = 0, 0, 1, 0.0001
for i = 1, 4 do
nx = nx + math.noise(t * freq, 0) * amp
nz = nz + math.noise(0, t * freq) * amp
freq = freq * 2.37
amp = amp * 0.5
end
local sp = t * 0.00073
nx = nx + math.noise(sp + 13.7, 7.3) * 0.3
nz = nz + math.noise(sp + 31.1, 17.9) * 0.3
local cp = t * 0.00213
nx = nx + math.sin(cp) * math.cos(cp * 1.618) * 0.2
nz = nz + math.cos(cp * 0.618) * math.sin(cp * 2.718) * 0.2
local len = math.sqrt(nx * nx + nz * nz)
if len < 0.001 then
local a = t * math.pi * 0.1
return math.cos(a), math.sin(a)
end
return nx / len, nz / len
end

local function stepVoidDrift_q(dt)
local p = Vector3.new(voidX_q, CFG.VOID_Y_BASE + voidYOffset_q, voidZ_q)
local m = CFG.VOID_METHOD
if m == "Stable" then
return p
elseif m == "Drift" then
local dx, dz = computeVoidDriftDir_q(elapsed_q)
voidDirX_q = voidDirX_q + (dx - voidDirX_q) * CFG.VOID_DRIFT_CHAOS * dt * 10
voidDirZ_q = voidDirZ_q + (dz - voidDirZ_q) * CFG.VOID_DRIFT_CHAOS * dt * 10
voidX_q = voidX_q + voidDirX_q * CFG.VOID_DRIFT_SPEED * dt
voidZ_q = voidZ_q + voidDirZ_q * CFG.VOID_DRIFT_SPEED * dt
voidYOffset_q = voidYOffset_q + voidYDir_q * CFG.VOID_Y_DRIFT_SPEED * dt
if math.abs(voidYOffset_q) >= CFG.VOID_Y_DRIFT_RANGE then
voidYDir_q = -voidYDir_q
end
return Vector3.new(voidX_q, CFG.VOID_Y_BASE + voidYOffset_q, voidZ_q)
elseif m == "Chaotic" then
voidX_q = voidX_q + (math.random() - 0.5) * CFG.VOID_DRIFT_SPEED * dt * 5
voidZ_q = voidZ_q + (math.random() - 0.5) * CFG.VOID_DRIFT_SPEED * dt * 5
voidYOffset_q = voidYOffset_q + (math.random() - 0.5) * CFG.VOID_Y_DRIFT_SPEED * dt * 5
return Vector3.new(voidX_q, CFG.VOID_Y_BASE + voidYOffset_q, voidZ_q)
elseif m == "Circle" then
local r = 1e9
return Vector3.new(voidX_q + math.cos(elapsed_q * 2) * r, CFG.VOID_Y_BASE + voidYOffset_q, voidZ_q + math.sin(elapsed_q * 2) * r)
elseif m == "Spiral" then
local r = 1e9 * (1 + math.sin(elapsed_q))
return Vector3.new(voidX_q + math.cos(elapsed_q * 3) * r, CFG.VOID_Y_BASE + voidYOffset_q, voidZ_q + math.sin(elapsed_q * 3) * r)
elseif m == "Lissajous" then
local r = 2e9
return Vector3.new(voidX_q + math.sin(elapsed_q * CFG.VOID_LISSAJOUS_A) * r, CFG.VOID_Y_BASE + voidYOffset_q, voidZ_q + math.sin(elapsed_q * CFG.VOID_LISSAJOUS_B) * r)
elseif m == "Flicker Void" then
return (tick() % (CFG.VOID_FLICKER_INT * 2) < CFG.VOID_FLICKER_INT)
and Vector3.new(voidX_q, CFG.VOID_Y_BASE, voidZ_q)
or  Vector3.new(-voidX_q, CFG.VOID_Y_BASE + 1e9, -voidZ_q)
elseif m == "Gravity Well" then
local t2 = elapsed_q * 0.5
local r = CFG.VOID_GRAVITY_STR * (1 + math.sin(t2))
return Vector3.new(voidX_q + math.cos(t2) * r, CFG.VOID_Y_BASE + math.sin(t2 * 0.7) * r, voidZ_q + math.sin(t2) * r)
elseif m == "Helix" then
local r = 1e9
local t2 = elapsed_q * 2
return Vector3.new(voidX_q + math.cos(t2) * r, CFG.VOID_Y_BASE + voidYOffset_q + math.sin(t2 * 0.5) * r, voidZ_q + math.sin(t2) * r)
elseif m == "Figure 8" then
local r = 1.5e9
local t2 = elapsed_q * 1.5
return Vector3.new(voidX_q + math.sin(t2) * r, CFG.VOID_Y_BASE + voidYOffset_q, voidZ_q + math.sin(t2) * math.cos(t2) * r)
elseif m == "Tornado" then
local r = 2e9 * math.abs(math.sin(elapsed_q))
local t2 = elapsed_q * 5
return Vector3.new(voidX_q + math.cos(t2) * r, CFG.VOID_Y_BASE + math.sin(elapsed_q * 2) * 1e9, voidZ_q + math.sin(t2) * r)
elseif m == "Quantum Tunneling" then
local r = 1e11 * (math.random() > 0.5 and 1 or -1)
return Vector3.new(voidX_q + r, CFG.VOID_Y_BASE + math.random(-1e8, 1e8), voidZ_q + r)
elseif m == "Fractal Desync" then
local t2 = elapsed_q * 5
local x = math.sin(t2) + math.sin(t2 * 2.1) / 2 + math.sin(t2 * 3.2) / 4
local z = math.cos(t2) + math.cos(t2 * 2.2) / 2 + math.cos(t2 * 3.1) / 4
return Vector3.new(voidX_q + x * 1e10, CFG.VOID_Y_BASE + math.sin(t2 * 10) * 1e9, voidZ_q + z * 1e10)
elseif m == "Extreme Desync" then
local t2 = elapsed_q * 15
local r = 1e12
return Vector3.new(voidX_q + math.sin(t2) * r, CFG.VOID_Y_BASE + math.cos(t2 * 1.5) * r * 0.1, voidZ_q + math.cos(t2) * r)
elseif m == "Frame Skip" then
local skip = (tick() % 0.1 < 0.05)
if skip then
return Vector3.new(voidX_q * 2, CFG.VOID_Y_BASE + 1e11, voidZ_q * 2)
end
return Vector3.new(voidX_q, CFG.VOID_Y_BASE, voidZ_q)
end
return p
end

