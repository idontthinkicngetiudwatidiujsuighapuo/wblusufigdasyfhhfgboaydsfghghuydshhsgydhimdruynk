RunService.RenderStepped:Connect(function()
    -- 1. CLOCK-IN (Check if UI is actually there)
    local T = getgenv().Toggles
    local O = getgenv().Options
    
    if not T or not O or not T.Master or not O.Target then 
        return 
    end

    -- 2. FORCE PLAYER LIST UPDATE (If empty, this fixes it)
    if tick() - lastRefresh > 2 then
        local names = {}
        for _, p in pairs(game:GetService("Players"):GetPlayers()) do
            if p ~= game:GetService("Players").LocalPlayer then 
                table.insert(names, p.Name) 
            end
        end
        
        -- Safe call to update dropdown
        pcall(function()
            O.Target:SetValues(names)
        end)
        lastRefresh = tick()
    end

    -- 3. IS THE TOGGLE ON?
    if not T.Master.Value then return end
    
    local char = game:GetService("Players").LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart

    -- 4. FINDING THE VICTIM
    local currentTarget = nil
    
    if T.Lock.Value and O.Target.Value then
        local p = game:GetService("Players"):FindFirstChild(tostring(O.Target.Value))
        if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            currentTarget = p
        end
    else
        local maxD = O.Dist.Value or 700
        for _, p in pairs(game:GetService("Players"):GetPlayers()) do
            if p ~= game:GetService("Players").LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local h = p.Character:FindFirstChild("Humanoid")
                if h and h.Health > 0 then
                    local d = (hrp.Position - p.Character.HumanoidRootPart.Position).Magnitude
                    if d < maxD then
                        maxD = d
                        currentTarget = p
                    end
                end
            end
        end
    end

    -- 5. THE ACTION
    if currentTarget and currentTarget.Character and currentTarget.Character:FindFirstChild("Head") then
        -- Print for proof (Delete this line once it works)
        print("Targeting: " .. currentTarget.Name)

        local targetHead = currentTarget.Character.Head
        local zOffset = O.Offset.Value or 10
        local baseCFrame = targetHead.CFrame * CFrame.new(0, 0, 3)
        local camPos = baseCFrame.Position + Vector3.new(0, 5, zOffset)
        
        workspace.CurrentCamera.CFrame = CFrame.new(camPos, targetHead.Position)

        if T.AA.Value then
            local sSpeed = O.Speed.Value or 1000
            local jInt = O.Jitter.Value or 1
            local jitter = Vector3.new(math.random(-jInt, jInt), math.random(-jInt, jInt), math.random(-jInt, jInt))
            hrp.CFrame = baseCFrame * CFrame.Angles(0, tick() * sSpeed, 0) + jitter
        else
            hrp.CFrame = baseCFrame
        end

        -- Transparency & Triggerbot
        for _, part in pairs(char:GetChildren()) do
            if part:IsA("BasePart") then part.LocalTransparencyModifier = 1 end
        end

        if mouse.Target and mouse.Target:IsDescendantOf(currentTarget.Character) then
            if mouse1click then mouse1click() end
        end
    end
end)

